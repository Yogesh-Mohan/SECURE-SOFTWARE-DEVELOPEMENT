
# MongoDB Configuration
DATABASE_NAME=adminsoftware-developement
MONGO_URL=mongodb://localhost:27017

# JWT Configuration
SECRET_KEY=your-super-secret-key-1234567890

# Email Configuration (Gmail)
# Use Gmail App Password for better security (not regular password)
# Steps to get App Password:
# 1. Go to myaccount.google.com
# 2. Enable 2-Factor Authentication
# 3. Go to Security > App passwords > Select Mail & Windows/Mac/Linux
# 4. Copy the 16-character password and paste here
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password-16-chars